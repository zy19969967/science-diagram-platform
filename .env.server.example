VITE_API_BASE_URL=
# Optional: set both values to the same secret to protect /api routes.
VITE_API_TOKEN=
GATEWAY_API_TOKEN=
FRONTEND_PUBLIC_PORT=19084
GATEWAY_BIND_HOST=127.0.0.1
GATEWAY_PUBLIC_PORT=19080

# Reserve these GPUs for this project on the server.
PROJECT_GPU_POOL=4,5,6,7
POWERPAINT_CUDA_VISIBLE_DEVICES=4
PLANNER_CUDA_VISIBLE_DEVICES=5
SEGMENTER_CUDA_VISIBLE_DEVICES=6
FLUX_CUDA_VISIBLE_DEVICES=7
HF_ENDPOINT=https://hf-mirror.com
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
TORCH_VERSION=2.5.1
TORCHVISION_VERSION=0.20.1

# Local FLUX-compatible initial-canvas service.
# Docker Compose defaults this to http://flux:8004.
FLUX_INIT_URL=
FLUX_BACKEND=diffusers
FLUX_MODEL_REPO=black-forest-labs/FLUX.1-schnell
FLUX_MODEL_DTYPE=bfloat16
FLUX_NUM_INFERENCE_STEPS=4
FLUX_GUIDANCE_SCALE=0.0
FLUX_MAX_SEQUENCE_LENGTH=256
FLUX_LOCAL_FILES_ONLY=false
# Gateway benchmark ledger directory inside the container.
BENCHMARKS_DIR=/app/data/benchmarks

PLANNER_BACKEND=qwen3.5
PLANNER_MODEL_REPO=Qwen/Qwen3.5-4B
PLANNER_MODEL_DTYPE=float16
PLANNER_MAX_NEW_TOKENS=320
PLANNER_ATTN_IMPL=sdpa
PLANNER_LOCAL_FILES_ONLY=false

SEGMENTER_BACKEND=sam2
SEGMENTER_MODEL_REPO=facebook/sam2.1-hiera-base-plus
SEGMENTER_MODEL_DTYPE=float16
SEGMENTER_LOCAL_FILES_ONLY=false
SEGMENTER_BOX_PADDING_RATIO=0.18
SEGMENTER_MASK_THRESHOLD=0.0
SEGMENTER_USE_PLACEMENT_BOX=false

POWERPAINT_GIT_REF=main
POWERPAINT_REPO_GIT_URL=https://github.com/zhuang2002/PowerPaint.git
POWERPAINT_MODEL_REPO=JunhaoZhuang/PowerPaint-v2-1
POWERPAINT_MODEL_GIT_URL=https://huggingface.co/JunhaoZhuang/PowerPaint-v2-1
POWERPAINT_DOWNLOAD_METHOD=git
# PowerPaint 2.1 still uses the BrushNet-based v2 inference path.
POWERPAINT_VERSION=ppt-v2
POWERPAINT_MODEL_DIR_NAME=ppt-v2-1
POWERPAINT_WEIGHT_DTYPE=float16
POWERPAINT_LOCAL_FILES_ONLY=false
