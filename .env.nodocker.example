# Project paths
PROJECT_ROOT=/home/common/yzhu_2025/science-diagram-platform
POWERPAINT_REPO_PATH=/home/common/yzhu_2025/PowerPaint
POWERPAINT_REPO_GIT_URL=https://github.com/zhuang2002/PowerPaint.git

# Service endpoints
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18000
PLANNER_HOST=127.0.0.1
PLANNER_PORT=8001
POWERPAINT_HOST=127.0.0.1
POWERPAINT_PORT=8002
SEGMENTER_HOST=127.0.0.1
SEGMENTER_PORT=8003

# Frontend
FRONTEND_STATIC_HOST=0.0.0.0
FRONTEND_STATIC_PORT=8080
PUBLIC_GATEWAY_BASE_URL=http://211.87.232.112:18000
VITE_API_BASE_URL=

# Runtime directories
MODELS_DIR=/home/common/yzhu_2025/science-diagram-platform/models
HF_HOME=/home/common/yzhu_2025/science-diagram-platform/models/huggingface
RUNS_DIR=/home/common/yzhu_2025/science-diagram-platform/data/runs
ASSETS_DIR=/home/common/yzhu_2025/science-diagram-platform/backend/assets

# Conda
CONDA_BIN=conda
CONDA_PYTHON_VERSION=3.10
CONDA_PYTHON_VERSION_POWERPAINT=3.10
CONDA_ENV_GATEWAY=sci-gateway
CONDA_ENV_PLANNER=sci-planner
CONDA_ENV_SEGMENTER=sci-segmenter
CONDA_ENV_POWERPAINT=sci-powerpaint
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121

# GPU allocation
POWERPAINT_CUDA_VISIBLE_DEVICES=4
PLANNER_CUDA_VISIBLE_DEVICES=5
SEGMENTER_CUDA_VISIBLE_DEVICES=6
AUX_CUDA_VISIBLE_DEVICES=7

# Planner
PLANNER_BACKEND=qwen3.5
PLANNER_MODEL_REPO=Qwen/Qwen3.5-4B
PLANNER_MODEL_DTYPE=float16
PLANNER_MAX_NEW_TOKENS=320
PLANNER_ATTN_IMPL=sdpa
PLANNER_LOCAL_FILES_ONLY=false

# Segmenter
SEGMENTER_BACKEND=sam2
SEGMENTER_MODEL_REPO=facebook/sam2.1-hiera-base-plus
SEGMENTER_MODEL_DTYPE=float16
SEGMENTER_LOCAL_FILES_ONLY=false
SEGMENTER_BOX_PADDING_RATIO=0.18
SEGMENTER_MASK_THRESHOLD=0.0
SEGMENTER_USE_PLACEMENT_BOX=false

# PowerPaint
POWERPAINT_MODEL_REPO=JunhaoZhuang/PowerPaint-v2-1
POWERPAINT_MODEL_GIT_URL=https://huggingface.co/JunhaoZhuang/PowerPaint-v2-1
POWERPAINT_DOWNLOAD_METHOD=git
# PowerPaint 2.1 still uses the BrushNet-based v2 inference path.
POWERPAINT_VERSION=ppt-v2
POWERPAINT_MODEL_DIR_NAME=ppt-v2-1
POWERPAINT_WEIGHT_DTYPE=float16
POWERPAINT_LOCAL_FILES_ONLY=false
